print("Movie Recommendation System")

# simple movie list
movies = {
    "avengers": ["iron man", "thor", "captain america"],
    "spiderman": ["venom", "batman", "superman"],
    "harry potter": ["lord of the rings", "narnia", "hobbit"],
    "fast and furious": ["need for speed", "rush", "transformers"],
    "interstellar": ["inception", "gravity", "martian"]
}

while True:
    print("\nMovies available:")
    
    # showing movies
    for m in movies:
        print(m)

    name = input("\nEnter movie name: ")
    name = name.lower()

    # checking movie
    if name in movies:
        print("Recommended movies are:")
        
        for i in movies[name]:
            print(i)
    else:
        print("Movie not in list")

    ch = input("\nTry again? (yes/no): ")
    if ch != "yes":
        print("Thank you")
        break
